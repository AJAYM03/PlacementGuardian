{
  "manifest_version": 3,
  "name": "Placement Guardian",
  "version": "1.0.0",
  "description": "Automated data entry and tracker for placement forms.",
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://docs.google.com/forms/*"
  ],"options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Placement Guardian"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["content.js"]
    }
  ],
  "oauth2": {
    "client_id": "972472278035-67shhfqm18o4ip9c195qmj67el1a6q6n.apps.googleusercontent.com",
    "scopes": ["email", "profile"]
  }
}